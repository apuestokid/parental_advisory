#dominio de desarrollo (coméntalo si vas a gastar localhost)
VITE_LOCALHOST_DOMAIN=my_dev_domain.test
VITE_LOCALHOST_PORT=5173
#DOMINIO del PROXY para evitar problemas de CORS en local:
VITE_PROXY_DOMAIN=https://app.my_backend_url.com

#Ruta base de la URL de la api de back:
VITE_APP_API_URL=https://app.my_backend_url.com/api 

#variable de entorno utilizada para indicar si el entorno actual es de desarrollo.
VITE_IS_DEVELOP=true

# Supabase (opcional): sincronización de usuarios/configuración de PantallaSana.
# Si se dejan vacías, la app funciona sin registro (solo localStorage).
# La anon key es pública por diseño (la seguridad la da RLS). NUNCA pongas la service_role.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# SOLO para seeders/scripts de servidor (npm run seed:admin). SECRETA: nunca con prefijo
# VITE_ (no debe acabar en el frontend) y nunca subir a Vercel ni al repo.
# Supabase → Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=



